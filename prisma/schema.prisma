generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  telegramId       String?           @unique
  telegramChatId   String?
  botStartedAt     DateTime?
  username         String?
  firstName        String?
  lastName         String?
  photoUrl         String?
  languageCode     String?
  providers        Provider[]
  reviews          Review[]
  inquiriesMade    ServiceInquiry[]  @relation("InquiryCustomer")
  recommendations  Recommendation[]
  reports          Report[]
  media            Media[]
  wallet           Wallet?
  giftsSent        GiftPayment[]     @relation("GiftSender")
  giftsReceived    GiftPayment[]     @relation("GiftRecipient")
  withdraws        WithdrawRequest[]
  telegramSessions TelegramSession[]
  reviewCodesMade  ReviewCode[]      @relation("ReviewCodeCreator")
  reviewCodesUsed  ReviewCode[]      @relation("ReviewCodeUser")
  suspendedAt      DateTime?
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Provider {
  id          String           @id @default(cuid())
  ownerUserId           String?
  owner                 User?            @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  previousOwnerUserId   String?
  ownerTransferredAt    DateTime?
  slug        String           @unique
  name        String
  bio         String
  avatar      String
  avatarTone  String
  services    Service[]
  media       Media[]
  reviewCodes ReviewCode[]
  inquiries   ServiceInquiry[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  services  Service[]
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Service {
  id              String           @id
  providerId      String
  provider        Provider         @relation(fields: [providerId], references: [id], onDelete: Cascade)
  categoryId      String
  category        Category         @relation(fields: [categoryId], references: [id])
  title           String
  price           Int
  ratingSnapshot  Float            @default(0)
  description     String
  iconName        String
  previewLabel    String
  ownerKind       String           @default("other")
  media           Media[]
  reviews         Review[]
  reviewCodes     ReviewCode[]
  inquiries       ServiceInquiry[]
  recommendations Recommendation[]
  reports         Report[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
}

model Media {
  id           String        @id @default(cuid())
  providerId   String?
  provider     Provider?     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  serviceId    String?
  service      Service?      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  authorUserId String?
  authorUser   User?         @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  isAnonymous  Boolean       @default(true)
  caption      String?
  type         String
  url          String
  thumbnailUrl String?
  altText      String
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  deletedAt    DateTime?
  giftPayments GiftPayment[]
}

model Review {
  id                 String      @id
  serviceId          String
  service            Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  authorUserId       String?
  authorUser         User?       @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  sentiment          String
  reviewScore        Float?
  status             String      @default("UNVERIFIED")
  verificationMethod String      @default("NONE")
  reviewCodeId       String?     @unique
  reviewCode         ReviewCode? @relation(fields: [reviewCodeId], references: [id], onDelete: SetNull)
  author             String
  text               String
  createdAt          DateTime    @default(now())
}

model ReviewCode {
  id              String          @id @default(cuid())
  serviceId       String
  service         Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  providerId      String
  provider        Provider        @relation(fields: [providerId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdByUser   User            @relation("ReviewCodeCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  usedByUserId    String?
  usedByUser      User?           @relation("ReviewCodeUser", fields: [usedByUserId], references: [id], onDelete: SetNull)
  codeHash        String          @unique
  status          String          @default("ACTIVE")
  customerChatId  String?
  inquiryId       String?
  inquiry         ServiceInquiry? @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  sentAt          DateTime?
  usedAt          DateTime?
  expiresAt       DateTime
  review          Review?
  createdAt       DateTime        @default(now())
}

model ServiceInquiry {
  id                         String       @id @default(cuid())
  serviceId                  String
  service                    Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  providerId                 String
  provider                   Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  customerUserId             String
  customerUser               User         @relation("InquiryCustomer", fields: [customerUserId], references: [id], onDelete: Cascade)
  status                     String       @default("REQUESTED")
  message                    String?
  providerMessageId          Int?
  providerNotificationStatus String?
  providerNotificationError  String?
  providerMessageEditedAt    DateTime?
  customerNotifiedAt         DateTime?
  customerNotificationStatus String?
  customerNotificationError  String?
  providerRespondedAt        DateTime?
  reviewInvitedAt            DateTime?
  reviewInviteStatus         String?
  reviewInviteError          String?
  reviewCodes                ReviewCode[]
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  @@unique([serviceId, customerUserId])
}

model Recommendation {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([serviceId, userId])
}

model Report {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String?
  createdAt DateTime @default(now())

  @@unique([serviceId, userId])
}

model TelegramSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  queryId     String?
  authDate    DateTime
  hash        String
  rawInitData String
  createdAt   DateTime @default(now())
  expiresAt   DateTime
}

model GiftPayment {
  id              String         @id @default(cuid())
  orderId         String         @unique
  mediaId         String
  media           Media          @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  senderUserId    String
  senderUser      User           @relation("GiftSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  recipientUserId String
  recipientUser   User           @relation("GiftRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  amount          Int
  fee             Int?
  totalPayment    Int?
  paymentMethod   String         @default("qris")
  paymentNumber   String
  qrImageDataUrl  String?
  status          String         @default("PENDING")
  completedAt     DateTime?
  expiredAt       DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  ledgerEntries   WalletLedger[]
}

model Wallet {
  id              String            @id @default(cuid())
  userId          String            @unique
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance         Int               @default(0)
  pendingWithdraw Int               @default(0)
  totalEarned     Int               @default(0)
  ledgerEntries   WalletLedger[]
  withdraws       WithdrawRequest[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model WalletLedger {
  id                String           @id @default(cuid())
  walletId          String
  wallet            Wallet           @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type              String
  amount            Int
  giftPaymentId     String?
  giftPayment       GiftPayment?     @relation(fields: [giftPaymentId], references: [id], onDelete: SetNull)
  withdrawRequestId String?
  withdrawRequest   WithdrawRequest? @relation(fields: [withdrawRequestId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())
}

model WithdrawRequest {
  id                  String         @id @default(cuid())
  walletId            String
  wallet              Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  userId              String
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount              Int
  method              String         @default("BI_FAST")
  accountName         String         @default("")
  accountNumber       String         @default("")
  adminFee            Int            @default(0)
  netAmount           Int            @default(0)
  payoutDetails       String
  status              String         @default("PENDING")
  developerNotifiedAt DateTime?
  paidAt              DateTime?
  rejectedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  ledgerEntries       WalletLedger[]
}
